{
  "expo": {
    "name": "QR & Barcode Scanner",
    "slug": "qr-clean",
    "version": "1.0.0",
    "scheme": "qrclean",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.qrclean.app",
      "infoPlist": {
        "NSCameraUsageDescription": "QR & Barcode Scanner necesita acceso a la cámara para escanear códigos QR y de barras."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.qrclean.app",
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "QR & Barcode Scanner necesita acceso a la cámara para escanear códigos QR y de barras."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
